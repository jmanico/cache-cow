{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Security": {
    "Hsts": {
      "MaxAgeDays": 365,
      "IncludeSubDomains": true,
      "Preload": true
    },
    "Csp": {
      "ReportOnly": true,
      "ReportEndpoint": "",
      "PaymentProcessorOrigins": {
        "FormAction": [],
        "FrameSrc": [],
        "ConnectSrc": []
      }
    },
    "Cors": {
      "AllowedOrigins": [],
      "AllowCredentials": false
    },
    "RequestLimits": {
      "MaxRequestBodyBytes": 1048576,
      "DefaultPageSize": 20,
      "MaxPageSize": 100
    },
    "RateLimiting": {
      "Default": { "PermitLimit": 600, "WindowSeconds": 60 },
      "Authentication": { "PermitLimit": 10, "WindowSeconds": 60 },
      "OrderCreation": { "PermitLimit": 60, "WindowSeconds": 60 }
    },
    "SessionCookies": {
      "SameSite": "Strict",
      "MaxAgeHours": 12
    }
  }
}
